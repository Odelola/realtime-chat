### 3. React Hook — `useChat`

A clean hook that manages connection, subscription lifecycle, initial history load, and scroll-up pagination:

```jsx
// src/hooks/useChat.js

import { useState, useEffect, useRef, useCallback } from "react";
import {
  connect,
  disconnect,
  subscribeToChannel,
  sendMessage,
} from "../services/websocket";
import { getChannelMessages, getMessagesBefore } from "../services/api";

export function useChat(channelId) {
  const [messages, setMessages] = useState([]);
  const [connected, setConnected] = useState(false);
  const [hasMore, setHasMore] = useState(true);
  const [loadingMore, setLoadingMore] = useState(false);
  const subscriptionRef = useRef(null);

  // Connect + subscribe + load initial history when channelId changes
  useEffect(() => {
    const token = localStorage.getItem("accessToken");
    if (!token || !channelId) return;

    let mounted = true;
    setMessages([]);
    setHasMore(true);

    async function init() {
      try {
        // Load the latest 50 messages from REST before opening the socket
        const history = await getChannelMessages(channelId, 0, 50);
        if (!mounted) return;
        // history.content comes back newest-first; reverse so oldest is at top
        setMessages(history.content.reverse());
        setHasMore(!history.last);

        await connect(token);
        if (!mounted) return;
        setConnected(true);

        // New live messages append to the bottom
        subscriptionRef.current = subscribeToChannel(channelId, (msg) => {
          if (mounted) {
            setMessages((prev) => [...prev, msg]);
          }
        });
      } catch (err) {
        console.error("Failed to connect:", err);
      }
    }

    init();

    return () => {
      mounted = false;
      if (subscriptionRef.current) {
        subscriptionRef.current.unsubscribe();
      }
      disconnect();
      setConnected(false);
    };
  }, [channelId]);

  // Call this when the user scrolls to the top to load older messages
  const loadMore = useCallback(async () => {
    if (!hasMore || loadingMore || messages.length === 0) return;

    setLoadingMore(true);
    try {
      // Use the createdAt of the oldest message we have as the cursor
      const oldest = messages[0].createdAt;
      const older = await getMessagesBefore(channelId, oldest, 50);
      if (older.length === 0) {
        setHasMore(false);
      } else {
        // Prepend older messages; they also come back newest-first so reverse them
        setMessages((prev) => [...older.reverse(), ...prev]);
        if (older.length < 50) setHasMore(false);
      }
    } finally {
      setLoadingMore(false);
    }
  }, [channelId, messages, hasMore, loadingMore]);

  const send = useCallback(
    (content, replyToId = null) => {
      if (channelId) {
        sendMessage(channelId, content, replyToId);
      }
    },
    [channelId]
  );

  return { messages, connected, send, loadMore, hasMore, loadingMore };
}
```

---

### 4. Example Component — `ChatRoom`

```jsx
// src/components/ChatRoom.jsx

import { useState, useRef, useEffect } from "react";
import { useChat } from "../hooks/useChat";

export default function ChatRoom({ channelId }) {
  const { messages, connected, send, loadMore, hasMore, loadingMore } = useChat(channelId);
  const [input, setInput] = useState("");
  const scrollRef = useRef(null);

  // Auto-scroll to bottom when new messages arrive
  useEffect(() => {
    if (scrollRef.current) {
      scrollRef.current.scrollTop = scrollRef.current.scrollHeight;
    }
  }, [messages.length]);

  const handleSend = (e) => {
    e.preventDefault();
    if (!input.trim()) return;
    send(input.trim());
    setInput("");
  };

  // Trigger loadMore when user scrolls to the top
  const handleScroll = () => {
    if (scrollRef.current?.scrollTop === 0) {
      loadMore();
    }
  };

  return (
    <div>
      <div>{connected ? "🟢 Connected" : "🔴 Disconnected"}</div>

      {/* Messages */}
      <div
        ref={scrollRef}
        onScroll={handleScroll}
        style={{ height: 400, overflowY: "auto" }}
      >
        {hasMore && (
          <div style={{ textAlign: "center", padding: 8 }}>
            {loadingMore ? "Loading..." : <button onClick={loadMore}>Load older messages</button>}
          </div>
        )}
        {messages.map((msg, i) => (
          <div key={msg.id || i}>
            <strong>{msg.authorUsername}</strong>: {msg.content}
          </div>
        ))}
      </div>

      {/* Input */}
      <form onSubmit={handleSend}>
        <input
          value={input}
          onChange={(e) => setInput(e.target.value)}
          placeholder="Type a message..."
          disabled={!connected}
        />
        <button type="submit" disabled={!connected}>Send</button>
      </form>
    </div>
  );
}
```

### 5. Usage

```jsx
// In your app/page
import ChatRoom from "./components/ChatRoom";

function App() {
  const channelId = "your-channel-uuid-here";
  return <ChatRoom channelId={channelId} />;
}
```

That's it. **3 files** (`api.js`, `websocket.js`, `useChat.js`) + 1 component and you're connected.

